
{% stylesheet %}
  .trust-carousel {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    position: relative;
    overflow: hidden;
    min-height: 120px;
    margin-top: 1.5rem;
    width: 100%;
  }

  .trust-carousel__track {
    flex: 1;
    height: auto;
    overflow: hidden;
    position: relative;
  }

  .trust-carousel__slides {
    display: flex;
    height: auto;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .trust-carousel__slide {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    height: auto;
    flex-shrink: 0;
    padding: 10px 0;
  }

  .trust-carousel__icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    background: #fff;
  }

  .trust-carousel__icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
  }

  .trust-carousel__icon-wrapper svg {
    width: 30px;
    height: 30px;
    color: #000;
  }

  .trust-carousel__content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    padding: 5px 0;
  }

  .trust-carousel__title {
    font-family: var(--font-galderglynn);
    font-size: 12px;
    font-weight: 300; 
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #000;
    margin: 0;
    line-height: 1.5;
  }

  .trust-carousel__subtitle {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #000;
    opacity: 0.5;
    margin: 0;
    font-weight: 300;
    line-height: 1.4;
  }

  .trust-carousel__dots {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 1rem;
    border-left: 1px solid rgba(0, 0, 0, 0.05);
  }

  .trust-carousel__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .trust-carousel__dot.is-active {
    background: #000;
    border-color: #000;
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .trust-carousel {
      min-height: 110px;
      gap: 1rem;
    }
    .trust-carousel__icon-wrapper {
      width: 50px;
      height: 50px;
    }
    .trust-carousel__title {
      font-size: 11px;
      letter-spacing: 0.2em;
      line-height: 1.6;
    }
    .trust-carousel__subtitle {
      font-size: 10px;
    }
  }
{% endstylesheet %}

<div class="trust-carousel" data-trust-carousel {{ block.shopify_attributes }}>
  <div class="trust-carousel__track">
    <div class="trust-carousel__slides" data-slides>
      <!-- Slide 1: Locally Made -->
      <div class="trust-carousel__slide">
        <div class="trust-carousel__icon-wrapper">
          <img src="https://cdn.shopify.com/s/files/1/0774/2894/9215/files/emirates.png?v=1777537116" alt="UAE Icon" width="60" height="60" loading="lazy">
        </div>
        <div class="trust-carousel__content">
          <h3 class="trust-carousel__title">Locally made</h3>
          <p class="trust-carousel__subtitle">proudly made in UAE</p>
        </div>
      </div>
      <!-- Slide 2: Gift Wrapping -->
      <div class="trust-carousel__slide">
        <div class="trust-carousel__icon-wrapper">
          <img src="https://cdn.shopify.com/s/files/1/0774/2894/9215/files/gift.png?v=1777537115" alt="Gift Icon" width="60" height="60" loading="lazy">
        </div>
        <div class="trust-carousel__content">
          <h3 class="trust-carousel__title">A BEAUTIFULLY WRAPPED GIFT SET</h3>
          <p class="trust-carousel__subtitle">with a Furoshiki scarf</p>
        </div>
      </div>
      <!-- Slide 3: International Delivery -->
      <div class="trust-carousel__slide">
        <div class="trust-carousel__icon-wrapper">
          <img src="https://cdn.shopify.com/s/files/1/0774/2894/9215/files/globe.png?v=1777537116" alt="Globe Icon" width="60" height="60" loading="lazy">
        </div>
        <div class="trust-carousel__content">
          <h3 class="trust-carousel__title">INTERNATIONAL DELIVERY</h3>
          <p class="trust-carousel__subtitle">Worldwide shipping available</p>
        </div>
      </div>
    </div>
  </div>

  <div class="trust-carousel__dots">
    <button class="trust-carousel__dot is-active" data-dot="0" aria-label="Slide 1"></button>
    <button class="trust-carousel__dot" data-dot="1" aria-label="Slide 2"></button>
    <button class="trust-carousel__dot" data-dot="2" aria-label="Slide 3"></button>
  </div>
</div>

<script>
  (function() {
    const initCarousel = () => {
      const carousels = document.querySelectorAll('[data-trust-carousel]');
      carousels.forEach(carousel => {
        const slidesContainer = carousel.querySelector('[data-slides]');
        const dots = carousel.querySelectorAll('[data-dot]');
        const slideCount = dots.length;
        let currentIndex = 0;
        let interval;

        const updateCarousel = (index) => {
          currentIndex = index;
          const offset = index * -100;
          slidesContainer.style.transform = `translateX(${offset}%)`;
          
          dots.forEach((dot, i) => {
            dot.classList.toggle('is-active', i === index);
          });
        };

        const startAutoPlay = () => {
          interval = setInterval(() => {
            const nextIndex = (currentIndex + 1) % slideCount;
            updateCarousel(nextIndex);
          }, 4500);
        };

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            clearInterval(interval);
            updateCarousel(index);
            startAutoPlay();
          });
        });

        startAutoPlay();
        updateCarousel(0);
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousel);
    } else {
      initCarousel();
    }
  })();
</script>

