{%- doc -%}
  @param [limit] - {number}
  @param [live_region] - {boolean}

  The maximum number of items in the cart to display. If the number of items in the cart is greater than this limit, the
  count will be displayed as "99+".
{%- enddoc -%}

{% assign item_count = 0 %}
{% for item in cart.items %}
  {% if item.variant_id != 48572858400991 %}
    {% assign item_count = item_count | plus: item.quantity %}
  {% endif %}
{% endfor %}

<div
  ref="cartBubble"
  class="cart-bubble{% if item_count == 0 %} visually-hidden{% endif %}"
  {% if item_count <= 99 %}
    data-maintain-ratio
  {% endif %}
>
  <span class="cart-bubble__background"></span>
  <span
    ref="cartBubbleText"
    class="cart-bubble__text"
    {% if live_region %}
      role="status"
    {% endif %}
  >
    <span class="visually-hidden">
      {{- 'accessibility.cart_count' | t -}}
      : {{ item_count }}
    </span>
    <span
      class="cart-bubble__text-count{% if item_count == 0 %} hidden{% endif %}"
      ref="cartBubbleCount"
      aria-hidden="true"
      data-testid="cart-bubble"
    >
      {%- if limit == blank or item_count < limit %}
        {{- item_count -}}
      {%- endif -%}
    </span>
  </span>
</div>
