
<dialog class="discount-success-popup" id="DiscountSuccessPopup" aria-hidden="true">
  <div class="discount-success-popup__container">
    <button class="discount-success-popup__close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
    
    <div class="discount-success-popup__inner">
      <!-- Confetti Canvas Background -->
      <div class="discount-success-popup__confetti-overlay"></div>

      <div class="discount-success-popup__hero">
        <div class="discount-success-popup__amount">40%</div>
        <div class="discount-success-popup__tag-wrapper">
          <div class="discount-success-popup__tag">OFF UNLOCKED</div>
        </div>
      </div>
      
      <div class="discount-success-popup__body">
        <h2 class="discount-success-popup__title">Enjoy your reward!</h2>
        <p class="discount-success-popup__text">You've unlocked an exclusive 40% discount for your order. Claim it now and finalize your selection.</p>
      </div>
      
      <div class="discount-success-popup__actions">
        <button class="discount-success-popup__btn primary" onclick="document.getElementById('DiscountSuccessPopup').close();">CLAIM DISCOUNT</button>
        <button class="discount-success-popup__btn secondary" onclick="document.getElementById('DiscountSuccessPopup').close();">CONTINUE SHOPPING</button>
      </div>
    </div>
  </div>
</dialog>

<style>
  .discount-success-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    max-width: none;
    max-height: none;
    overflow: visible;
  }

  .discount-success-popup[open] {
    display: flex;
  }

  .discount-success-popup::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .discount-success-popup__container {
    position: relative;
    background: #111; /* Dark theme background */
    width: 90%;
    max-width: 400px;
    padding: 0;
    box-shadow: 0 30px 60px rgba(0,0,0,0.8);
    border-radius: 24px; /* Rounded corners like in image */
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    animation: popupSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes popupSlideUp {
    from { transform: translateY(50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .discount-success-popup__close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255,255,255,0.1);
    border: none;
    cursor: pointer;
    color: #fff;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s ease;
  }

  .discount-success-popup__close:hover {
    background: #fff;
    color: #000;
  }

  .discount-success-popup__inner {
    padding: 60px 30px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .discount-success-popup__hero {
    margin-bottom: 30px;
    text-align: center;
    position: relative;
  }

  .discount-success-popup__amount {
    font-family: var(--font-galderglynn);
    font-size: 80px;
    line-height: 1;
    color: #fff;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: -2px;
    text-shadow: 0 0 20px rgba(255,255,255,0.2);
  }

  .discount-success-popup__tag-wrapper {
    display: flex;
    justify-content: center;
    margin-top: -5px;
  }

  .discount-success-popup__tag {
    background: #eee;
    color: #000;
    padding: 8px 20px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    transform: perspective(100px) rotateX(10deg);
  }

  .discount-success-popup__body {
    text-align: center;
    margin-bottom: 40px;
  }

  .discount-success-popup__title {
    color: #fff;
    font-size: 20px;
    margin: 0 0 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .discount-success-popup__text {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 280px;
  }

  .discount-success-popup__actions {
    display: flex;
    flex-direction: column;
    gap: 15px;
    width: 100%;
  }

  .discount-success-popup__btn {
    width: 100%;
    padding: 18px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 50px; /* Pill shaped like in image */
  }

  .discount-success-popup__btn.primary {
    background: #fff;
    color: #000;
    border: none;
    box-shadow: 0 10px 20px rgba(255,255,255,0.1);
  }

  .discount-success-popup__btn.primary:hover {
    transform: scale(1.02);
    background: #f0f0f0;
  }

  .discount-success-popup__btn.secondary {
    background: transparent;
    color: rgba(255,255,255,0.4);
    border: none;
    font-size: 10px;
    padding: 5px;
  }

  .discount-success-popup__btn.secondary:hover {
    color: #fff;
  }

  /* Confetti-like background particles (simplified) */
  .discount-success-popup__confetti-overlay::before {
    content: "•";
    position: absolute;
    color: rgba(255,255,255,0.1);
    top: 20%; left: 10%; font-size: 20px;
    animation: drift 10s infinite linear;
  }
  
  @keyframes drift {
    from { transform: translateY(0) rotate(0deg); }
    to { transform: translateY(100px) rotate(360deg); }
  }

  @media screen and (max-width: 500px) {
    .discount-success-popup__container {
      width: 85%;
    }
    .discount-success-popup__amount {
      font-size: 70px;
    }
  }
</style>
