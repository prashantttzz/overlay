
{%- style -%}
  #contact-redesign-{{ section.id }} {
    background-color: #f7f7f7; /* Subtle off-white to make white glass pop */
    color: #000;
    min-height: 100vh;
    font-family: var(--font-body--family), sans-serif;
    position: relative;
    padding: 100px 0;
    overflow: hidden;
  }

  .contact-discovery__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .contact-discovery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 50/50 split */
    gap: 80px;
    align-items: center;
  }

  /* Right Side: Form Card - Noir Black */
  .contact-form-card {
    background-color: #000;
    border-radius: 30px;
    padding: 60px;
    color: #fff;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.1);
    position: relative;
    z-index: 5;
  }

  .contact-form-card__title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 40px;
    opacity: 0.7;
    color: #fff;
  }

  .discovery-form__label {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
  }

  .discovery-form__input {
    width: 100%;
    background: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 18px 24px;
    margin-bottom: 20px;
    font-size: 1rem;
    color: #fff !important;
    transition: all 0.3s ease;
  }

  .discovery-form__input::placeholder {
    color: rgba(255, 255, 255, 0.4); /* Muted grey placeholder */
  }

  .discovery-form__input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.15) !important;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .discovery-form__button {
    background: #fff;
    color: #000;
    border: none;
    border-radius: 50px;
    padding: 18px 40px;
    font-size: 0.9rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 20px;
  }

  .discovery-form__button:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.1);
  }

  .discovery-form__button svg {
    width: 18px;
    height: 18px;
  }

  /* Right Side: Info */
  .discovery-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f4f4f4;
    padding: 8px 16px;
    background-color: #c2c2c2;
    border-radius: 50px;
    }

  .discovery-badge__dot {
    width: 16px;
    height: 16px;
    background: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .discovery-badge__dot svg {
    width: 8px;
    height: 8px;
    color: #fff;
  }

  .discovery-badge span {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .discovery-info__heading {
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 25px;
    color: #000;
  }

  .discovery-info__heading em {
    font-style: italic;
    color: #888;
    font-weight: 400;
  }

  .discovery-info__description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 50px;
    max-width: 500px;
  }

  .discovery-info__details {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
  }

  .discovery-info__item {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .discovery-info__icon {
    width: 34px;
    height: 34px;
    background: #000;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .discovery-info__icon svg {
    width: 13px;
    height: 13px;
  }

  .discovery-info__text {
    font-size: 0.8rem;
    font-weight: 500;
    color: #000;
    text-decoration: none;
  }

  @media screen and (max-width: 990px) {
    .contact-discovery__grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .contact-discovery__container {
      padding: 0 20px;
    }
    #contact-redesign-{{ section.id }} {
      padding: 60px 0;
    }
    .contact-form-card {
      padding: 40px 30px;
    }
    .discovery-info {
      order: -1;
      text-align: center;
    }
    .discovery-info__heading {
      font-size: 2rem !important; /* Smaller on mobile */
      margin-bottom: 15px;
    }
    .discovery-info__description {
      font-size: 0.6rem !important; /* Smaller on mobile */
      margin-bottom: 30px;
      margin-left: auto;
      margin-right: auto;
    }
    .discovery-info__details {
      flex-direction: row; /* Stacked: one item per line */
      align-items: center;
      gap: 20px;
    }
    .discovery-badge {
      margin-top: 20px;
    }

    /* Smaller form text and less rounded on mobile */
    .contact-form-card {
      border-radius: 15px; /* Less rounded card */
      padding: 30px 20px;
    }
    .discovery-form__input {
      font-size: 0.85rem !important;
      padding: 12px 16px;
      border-radius: 6px; /* Less rounded inputs */
    }
    .discovery-form__label {
      font-size: 0.75rem;
    }
    .discovery-form__button {
      font-size: 0.8rem;
      padding: 14px 30px;
    }
  }
{%- endstyle -%}

<div id="contact-redesign-{{ section.id }}" class="contact-discovery">
  <div class="contact-discovery__container">
    <div class="contact-discovery__grid">
      <!-- Left Side: Info Content -->
      <div class="discovery-info">
        <div class="discovery-badge">
          <div class="discovery-badge__dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          </div>
          <span>Contact Us</span>
        </div>

        <h1 class="discovery-info__heading">
          Get in Touch With Us <em>Today</em>
        </h1>
        
        <p class="discovery-info__description">
          Ready to explore our olfactory artifacts? Whether you need assistance with a curation or a personal inquiry, our studio is here to assist.
        </p>

        <div class="discovery-info__details">
          <div class="discovery-info__item">
            <div class="discovery-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.21z"></path></svg>
            </div>
            <span class="discovery-info__text">+18371873818</span>
          </div>

          <div class="discovery-info__item">
            <div class="discovery-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <span class="discovery-info__text">Architectural Blvd, SE1</span>
          </div>

          <div class="discovery-info__item">
            <div class="discovery-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <a href="mailto:studio@overlay.com" class="discovery-info__text">studio@overlay.com</a>
          </div>
        </div>
      </div>

      <!-- Right Side: Form Card -->
      <div class="contact-form-card">
        <div class="contact-form-card__title">Send a message</div>
        
        {%- form 'contact', id: 'ContactForm', class: 'discovery-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success-message" style="margin-bottom: 30px; color: #fff; font-weight: 600;">
              MESSAGE SENT SUCCESSFULLY.
            </div>
          {%- endif -%}

          <div class="discovery-form__field">
            <label class="discovery-form__label" for="Discovery-Name">Your name</label>
            <input
              class="discovery-form__input"
              type="text"
              name="contact[name]"
              id="Discovery-Name"
              placeholder="Name"
              required
            >
          </div>

          <div class="discovery-form__field">
            <label class="discovery-form__label" for="Discovery-Email">Your email</label>
            <input
              class="discovery-form__input"
              type="email"
              name="contact[email]"
              id="Discovery-Email"
              placeholder="Email address"
              required
            >
          </div>

          <div class="discovery-form__field">
            <label class="discovery-form__label" for="Discovery-Message">Message</label>
            <textarea
              class="discovery-form__input"
              rows="4"
              name="contact[body]"
              id="Discovery-Message"
              placeholder="How can we help?"
            ></textarea>
          </div>

          <div class="discovery-form__submit">
            <button type="submit" class="discovery-form__button">
              Submit
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Redesign",
  "settings": [],
  "presets": [
    {
      "name": "Contact Redesign"
    }
  ]
}
{% endschema %}
