
{%- liquid
  assign section_id = 'section-' | append: section.id
-%}

{%- liquid
  # The hero always has a background (video or image)
  assign has_bg = true
-%}

{%- style -%}
  #{{ section_id }} {
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: #000;
    color: #fff;
    overflow: hidden;
    position: relative;
    --neon-green: #d7ff00;
    clip-path: inset(0 0 0 0);
    z-index: 1; 
  }

  .overlay-hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 90vh;
    padding-top: calc(var(--padding-top) + 80px);
    padding-bottom: var(--padding-bottom);
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: 2rem;
  }

  @media screen and (min-width: 990px) {
    .overlay-hero {
      min-height: 100vh;
    }
  }

  /* Video Background */
  .overlay-hero__video-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1; /* Goes behind the content but within the section's stacking context */
    pointer-events: none;
  }

  .overlay-hero__video-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2;
  }

  .overlay-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: hero-video-zoom 15s ease-in-out infinite alternate;
  }

  @keyframes hero-video-zoom {
    from { transform: scale(1.1); }
    to { transform: scale(1.25); }
  }

  .overlay-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    max-width: 900px;
    opacity: 1; /* Instant visibility */
    transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .overlay-hero__heading {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 0.5; /* Aggressively tightened to remove vertical gap */
    font-weight: 300;
    text-transform: uppercase;
    margin: 0;
    font-family: var(--font-galderglynn);
    letter-spacing: 0.04em;
    color: #fff;
    white-space: pre-line;
  }

  .overlay-hero__description {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 300;
    max-width: 600px;
    letter-spacing: 0.05em;
  }

  .overlay-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #fff; /* Solid white background */
    color: #000;
    padding: 1rem 3rem;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    border: 1px solid #fff;
    margin-top: 1rem;
    white-space: nowrap; /* Prevent button text wrapping */
  }

  .overlay-hero__button:hover {
    background-color: transparent;
    color: #fff;
  }

  @media (max-width: 768px) {
    .overlay-hero__heading {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
      line-height: 1.1;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      white-space: nowrap; /* Force each line to stay whole */
    }
    
    .overlay-hero__description {
      font-size: 8px; 
      letter-spacing: 0.3em;
      white-space: nowrap;
      max-width: 95vw;
      opacity: 0.8;
      text-transform: uppercase;
    }

    .overlay-hero__button {
      padding: 0.8rem 2.2rem;
      font-size: 10px;
      letter-spacing: 0.3em;
      background-color: #fff !important; /* Force visibility */
      color: #000 !important;
    }
  }

  /* Marquee */
  .overlay-hero__marquee {
    background-color: black;
    color: #ffffffff;
    padding: 1.25rem 0;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    z-index: 3;
    display: flex;
  }

  .overlay-hero__marquee-inner {
    display: flex;
    align-items: center;
    animation: marquee-scroll 200s linear infinite;
    flex-shrink: 0;
  }

  .overlay-hero__marquee-text {
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    padding: 0 1.5rem;
    letter-spacing: 0.1em;
  }

  .overlay-hero__marquee-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #000;
    border-radius: 50%;
    margin: 0 1.5rem;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-100%); }
  }
{%- endstyle -%}

<section id="{{ section_id }}" data-home-hero>
  <div class="overlay-hero__video-wrapper">
    <video 
      class="overlay-hero__video" 
      autoplay 
      loop 
      muted 
      playsinline 
      {%- if section.settings.image != blank -%}
        poster="{{ section.settings.image | image_url: width: 2000 }}"
      {%- endif -%}
    >
      <source src="{{ section.settings.video_url | default: 'https://cdn.shopify.com/videos/c/o/v/dcd2211b302f47169295b9baf0652208.mp4' }}" type="video/mp4">
    </video>
  </div>

  <div class="overlay-hero">
    <div class="overlay-hero__content">

      {%- if section.settings.heading != blank -%}
        <h1 class="overlay-hero__heading reveal reveal--fade-up reveal--stagger-1">{{ section.settings.heading | newline_to_br }}</h1>
      {%- endif -%}

      <div class="overlay-hero__description-wrapper reveal reveal--fade-up reveal--stagger-2">
        {%- if section.settings.description != blank -%}
          <p class="overlay-hero__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="overlay-hero__button reveal reveal--scale reveal--stagger-3">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

    {%- if section.settings.show_marquee -%}
    <div class="overlay-hero__marquee">
      <div class="overlay-hero__marquee-inner">
        {%- for i in (1..10) -%}
          <span class="overlay-hero__marquee-text">{{ section.settings.marquee_text }}</span>
          <span class="overlay-hero__marquee-dot"></span>
        {%- endfor -%}
      </div>
      <div class="overlay-hero__marquee-inner" aria-hidden="true">
        {%- for i in (1..10) -%}
          <span class="overlay-hero__marquee-text">{{ section.settings.marquee_text }}</span>
          <span class="overlay-hero__marquee-dot"></span>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Overlay Modern Hero",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video Background URL",
      "default": "https://cdn.shopify.com/videos/c/o/v/dcd2211b302f47169295b9baf0652208.mp4"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "ALL OVER\nTHE SPRAY\nHOUSE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "overlay is a modern fragrance house exploring the art of layering, where scents meet to create endless combinations with ease"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback Background Image"
    },
    {
      "type": "header",
      "content": "Marquee"
    },
    {
      "type": "checkbox",
      "id": "show_marquee",
      "label": "Show Marquee",
      "default": true
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee Text",
      "default": "NEW ARCHIVE DROP / STUDIO EXCLUSIVE • SENSE & ARCHITECTURE • REFRACTED ART COLLECTION AVAILABLE NOW • LIMITED EDITION SCENTS"
    },
    {
      "type": "header",
      "content": "Styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Note",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Overlay Modern Hero"
    }
  ]
}
{% endschema %}
