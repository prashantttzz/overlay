{{ 'collection-custom-redesign.css' | asset_url | stylesheet_tag }}

<style>
  /* Bulletproof Header Overrides for Collection Page */
  .template-collection #header-component,
  body[data-template*="collection"] #header-component {
    background-color: transparent !important;
    border-bottom: none !important;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
  }

  .template-collection #header-component.is-on-home-hero,
  body[data-template*="collection"] #header-component.is-on-home-hero {
    --menu-top-level-font-color: #fff !important;
    color: #fff !important;
  }

  .template-collection #header-component.is-on-home-hero .menu-list__link,
  body[data-template*="collection"] #header-component.is-on-home-hero .menu-list__link {
    color: #fff !important;
  }

  .template-collection #header-component.is-on-home-hero .header-logo__image,
  body[data-template*="collection"] #header-component.is-on-home-hero .header-logo__image {
    filter: none !important;
  }

  .template-collection #header-component.is-on-home-hero .header-actions__action svg,
  .template-collection #header-component.is-on-home-hero .header__icon--menu svg,
  body[data-template*="collection"] #header-component.is-on-home-hero .header-actions__action svg,
  body[data-template*="collection"] #header-component.is-on-home-hero .header__icon--menu svg {
    color: #fff !important;
    stroke: #fff !important;
    fill: none !important;
  }

  /* Scrolled State */
  .template-collection #header-component.is-scrolled:not(.is-on-home-hero),
  body[data-template*="collection"] #header-component.is-scrolled:not(.is-on-home-hero) {
    background-color: rgba(255, 255, 255, 0.75) !important;
    backdrop-filter: blur(20px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
  }

  .template-collection #header-component.is-scrolled:not(.is-on-home-hero) .menu-list__link,
  body[data-template*="collection"] #header-component.is-scrolled:not(.is-on-home-hero) .menu-list__link {
    color: #000 !important;
  }

  .template-collection #header-component.is-scrolled:not(.is-on-home-hero) .header-logo__image,
  body[data-template*="collection"] #header-component.is-scrolled:not(.is-on-home-hero) .header-logo__image {
    filter: invert(1) !important;
  }

  .template-collection #header-component.is-scrolled:not(.is-on-home-hero) .header-actions__action svg,
  .template-collection #header-component.is-scrolled:not(.is-on-home-hero) .header__icon--menu svg,
  body[data-template*="collection"] #header-component.is-scrolled:not(.is-on-home-hero) .header-actions__action svg,
  body[data-template*="collection"] #header-component.is-scrolled:not(.is-on-home-hero) .header__icon--menu svg {
    color: #000 !important;
    stroke: #000 !important;
    fill: none !important;
  }
</style>

<div class="template-collection-wrapper">
  <!-- 1. Small Hero Banner -->
  <div class="collection-small-banner" data-home-hero>
    <div class="small-banner__bg">
      <img src="https://cdn.shopify.com/s/files/1/0774/2894/9215/files/wew.jpg?v=1777636205" alt="Collection Banner">
    </div>
  </div>

  <!-- 2. Collection Title & Integrated Utilities Row -->
  <div class="collection-title-header">
    <div class="title-left-side">
      <div class="breadcrumb-nav">Home • {{ collection.title }}</div>
      <h1 class="collection-main-title">{{ collection.title | default: "Archival Collection" }}</h1>
    </div>

    <div class="title-center-utility">
      <div class="top-bar-search">
        <form action="{{ routes.search_url }}" method="get" role="search" class="pill-search-form">
          <div class="search-icon-cute">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <input 
            type="text" 
            name="q" 
            placeholder="SEARCH" 
            class="pill-search-input"
            value="{{ search.terms | escape }}"
          >
          <button type="submit" class="pill-search-submit-hidden"></button>
        </form>
      </div>
    </div>

    <div class="title-right-side-utility">
      <div class="top-bar-sort">
        <div class="custom-sort-dropdown" id="SortDropdown">
          <div class="sort-dropdown__trigger">
            <span class="current-sort">
              SORT: 
              {%- for option in collection.sort_options -%}
                {%- if option.value == collection.sort_by -%}{{ option.name }}{%- endif -%}
              {%- endfor -%}
              {%- if collection.sort_by == blank -%}Featured{%- endif -%}
            </span>
            <svg width="10" height="10" viewBox="0 0 10 10"><path d="M1 3L5 7L9 3" stroke="currentColor" fill="none"/></svg>
          </div>
          <div class="sort-dropdown__options">
            {%- for option in collection.sort_options -%}
              <div class="sort-dropdown__option {% if option.value == collection.sort_by %}is-selected{% endif %}" 
                   onclick="window.location.href = window.location.pathname + '?sort_by={{ option.value }}'">
                {{ option.name }}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <results-list
    class="collection-container-full"
    section-id="{{ section.id }}"
  >

    <!-- Main Content Layout -->
    <main class="main-content-full" id="ResultsList">
      <div class="collection-layout-wrapper">
        <!-- Left Sidebar Filters -->
        <aside class="collection-sidebar-left">
          {%- if collection.filters.size > 0 -%}
            <div class="sidebar-block filters-block">
              <div class="sidebar-title-row">
                <h4 class="sidebar-title">Filters</h4>
                <a href="{{ collection.url }}?sort_by={{ collection.sort_by }}" class="clear-filters">Reset</a>
              </div>
              <form class="sidebar-filters-form">
                {%- for filter in collection.filters -%}
                  <div class="filter-group">
                    <div class="filter-group-header">
                      <span class="filter-label">{{ filter.label }}</span>
                      <a href="{{ filter.url_to_remove }}" class="filter-group-reset">Reset</a>
                    </div>
                    <div class="filter-group-content">
                      {%- case filter.type -%}
                        {%- when 'list' -%}
                          <ul class="filter-list">
                            {%- for value in filter.values -%}
                              <li class="filter-item">
                                <label class="filter-checkbox-label">
                                  <input type="checkbox"
                                    name="{{ value.param_name }}"
                                    value="{{ value.value }}"
                                    {% if value.active %}checked{% endif %}
                                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                    onchange="this.form.submit()"
                                  >
                                  <span class="checkbox-box"></span>
                                  <span class="filter-value-text">{{ value.label }}</span>
                                  <span class="filter-value-count">{{ value.count }}</span>
                                </label>
                              </li>
                            {%- endfor -%}
                          </ul>
                          {% if filter.values.size > 6 %}
                            <div class="filter-show-more-wrapper">
                              <button type="button" class="filter-show-more-link">Show more +</button>
                            </div>
                          {% endif %}
                        {%- when 'price_range' -%}
                          <div class="filter-price-slider">
                             <div class="price-range-labels">
                               <span>{{ filter.min_value.value | money_without_currency | default: 0 }}</span>
                               <span>{{ filter.max_value.value | money_without_currency | default: filter.range_max | money_without_currency }}</span>
                             </div>
                             <div class="price-slider-track"></div>
                          </div>
                      {%- endcase -%}
                    </div>
                  </div>
                {%- endfor -%}
              </form>
            </div>
          {%- endif -%}
        </aside>

        <div class="collection-grid-content">
          {% paginate collection.products by section.settings.products_per_page %}
            <div class="product-grid-new" id="product-grid">
              {% for product in collection.products %}
                {% render 'noir-product-card', product: product %}
              {% endfor %}
            </div>

            <!-- Pagination UI -->
            {% if paginate.pages > 1 %}
              <div class="pagination-ui">
                <div class="pagination-links">
                  {% if paginate.previous %}
                    <a href="{{ paginate.previous.url }}" class="pagination-link">PREV</a>
                  {% endif %}

                  {% for part in paginate.parts %}
                    {% if part.is_link %}
                      <a href="{{ part.url }}" class="pagination-link">{{ part.title }}</a>
                    {% else %}
                      <span class="pagination-link {% if part.title == paginate.current_page %}is-active{% endif %}">{{ part.title }}</span>
                    {% endif %}
                  {% endfor %}

                  {% if paginate.next %}
                    <a href="{{ paginate.next.url }}" class="pagination-link">NEXT</a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    </main>
  </results-list>
  <!-- Mobile Sticky Bottom Bar -->
  <div class="mobile-sticky-bar">
    <button class="mobile-bar-btn" id="mobileSortBtn" onclick="document.getElementById('MobileSortDrawer').classList.add('is-open')">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 10L11 15"></path><path d="M21 19l-5-5-5 5"></path></svg>
      <span>SORT</span>
    </button>
    <div class="mobile-bar-divider"></div>
    <button class="mobile-bar-btn" id="mobileFilterBtn" onclick="document.getElementById('MobileFilterDrawer').classList.add('is-open')">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
      <span>FILTER</span>
    </button>
  </div>

  <!-- Mobile Drawers -->
  <div class="mobile-drawer" id="MobileFilterDrawer">
    <div class="drawer-header">
      <h3>Filters</h3>
      <button class="drawer-close" onclick="this.closest('.mobile-drawer').classList.remove('is-open')">&times;</button>
    </div>
    <div class="drawer-content">
      <div class="sidebar-clone">
        <form class="mobile-filter-form">
          {%- for filter in collection.filters -%}
            <div class="filter-group">
              <div class="filter-group-header">
                <span class="filter-label">{{ filter.label }}</span>
                <a href="{{ filter.url_to_remove }}" class="filter-group-reset">Reset</a>
              </div>
              <div class="filter-group-content">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    <ul class="filter-list">
                      {%- for value in filter.values -%}
                        <li class="filter-item">
                          <label class="filter-checkbox-label">
                            <input type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              onchange="this.form.submit()"
                            >
                            <span class="checkbox-box"></span>
                            <span class="filter-value-text">{{ value.label }}</span>
                            <span class="filter-value-count">{{ value.count }}</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- when 'price_range' -%}
                    <div class="filter-price-slider">
                       <div class="price-range-labels">
                         <span>{{ filter.min_value.value | money_without_currency | default: 0 }}</span>
                         <span>{{ filter.max_value.value | money_without_currency | default: filter.range_max | money_without_currency }}</span>
                       </div>
                       <div class="price-slider-track"></div>
                    </div>
                {%- endcase -%}
              </div>
            </div>
          {%- endfor -%}
        </form>
      </div>
    </div>
  </div>

  <div class="mobile-drawer" id="MobileSortDrawer">
    <div class="drawer-header">
      <h3>Sort By</h3>
      <button class="drawer-close" onclick="this.closest('.mobile-drawer').classList.remove('is-open')">&times;</button>
    </div>
    <div class="drawer-content">
      <div class="mobile-sort-list">
        {%- for option in collection.sort_options -%}
          <div class="mobile-sort-option {% if option.value == collection.sort_by %}active{% endif %}" 
               onclick="window.location.href = window.location.pathname + '?sort_by={{ option.value }}'">
            {{ option.name }}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          // Add a slight stagger delay based on position in viewport
          setTimeout(() => {
            entry.target.classList.add('is-visible');
          }, index % 4 * 100); 
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-item').forEach(item => {
      observer.observe(item);
    });

    // Sort Dropdown Click Toggle
    const sortDropdown = document.getElementById('SortDropdown');
    if (sortDropdown) {
      const trigger = sortDropdown.querySelector('.sort-dropdown__trigger');
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        sortDropdown.classList.toggle('is-active');
      });

      document.addEventListener('click', (e) => {
        if (!sortDropdown.contains(e.target)) {
          sortDropdown.classList.remove('is-active');
        }
      });
    }    // Robust AJAX Search within page
    const productGrid = document.querySelector('.product-grid-new');

    document.querySelectorAll('form[action="/search"]').forEach(form => {
      form.addEventListener('submit', function(e) {
        // Only run AJAX if we are on the redesign collection page
        if (!productGrid) return;

        e.preventDefault();
        e.stopImmediatePropagation();

        const searchTerm = this.querySelector('input[name="q"]').value;
        const searchUrl = `/search?q=${encodeURIComponent(searchTerm)}&type=product`;

        // Show loading state
        productGrid.style.opacity = '0.3';
        productGrid.style.transition = 'opacity 0.3s ease';
        productGrid.style.pointerEvents = 'none';

        fetch(searchUrl)
          .then(response => response.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            const newGrid = doc.querySelector('.product-grid-new') || 
                            doc.querySelector('.product-grid') || 
                            doc.querySelector('.grid-container') ||
                            doc.querySelector('.main-collection-grid');
            
            if (newGrid && (newGrid.children.length > 0 || newGrid.innerHTML.trim() !== '')) {
              productGrid.innerHTML = newGrid.innerHTML;
              
              if (!productGrid.classList.contains('product-grid-new')) {
                productGrid.classList.add('product-grid-new');
              }

              if (typeof observer !== 'undefined') {
                document.querySelectorAll('.reveal-item').forEach(item => {
                  observer.observe(item);
                });
              }
            } else {
              productGrid.innerHTML = '<div class="no-results-noir" style="grid-column: 1/-1; text-align: center; padding: 100px 0; font-family: var(--font-galderglynn); letter-spacing: 0.1em; text-transform: uppercase;">NO ARCHIVAL PIECES FOUND FOR: ' + searchTerm.toUpperCase() + '</div>';
            }
            
            productGrid.style.opacity = '1';
            productGrid.style.pointerEvents = 'auto';

            productGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
            window.history.pushState({}, '', `/search?q=${encodeURIComponent(searchTerm)}`);
          })
          .catch(err => {
            console.error('AJAX Search failed:', err);
            window.location.href = searchUrl; 
          });
      });
    });
  });

  // Robust Parallax Effect
  window.addEventListener('scroll', () => {
    const banner = document.querySelector('.collection-hero-banner');
    const parallaxBg = document.querySelector('.parallax-bg img');
    if (banner && parallaxBg) {
      const scrollPos = window.pageYOffset;
      const bannerTop = banner.offsetTop;
      const bannerHeight = banner.offsetHeight;
      
      // Calculate parallax only when banner is in view
      if (scrollPos + window.innerHeight > bannerTop && scrollPos < bannerTop + bannerHeight) {
        const offset = (scrollPos - bannerTop) * 0.3;
        parallaxBg.style.transform = `translate3d(0, ${offset}px, 0)`;
      }
    }
  });
</script>
</div>

{% schema %}
{
  "name": "Collection Redesign",
  "settings": [
    {
      "type": "header",
      "content": "Split Banner"
    },
    {
      "type": "image_picker",
      "id": "hero_image_left",
      "label": "Left Panel Image (Lifestyle)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_right",
      "label": "Right Panel Image (Product)"
    },
    {
      "type": "text",
      "id": "hero_heading_modern",
      "label": "Modern Heading",
      "default": "ethical beauty, sustainable impact."
    },
    {
      "type": "textarea",
      "id": "hero_subheading",
      "label": "Subheading",
      "default": "Committed to sustainable beauty and minimal impact for the planet."
    },
    {
      "type": "header",
      "content": "Catalog Header"
    },
    {
      "type": "text",
      "id": "catalog_label",
      "label": "Active Tab Label",
      "default": "best sellers"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    }
  ],
  "presets": [
    {
      "name": "Collection Redesign"
    }
  ]
}
{% endschema %}
