{{ 'footer-custom.css' | asset_url | stylesheet_tag }}

<footer class="footer-custom">
  <div class="footer-custom__inner page-width-normal">
    <div class="footer-custom__top">
      
      <!-- Brand Column -->
      <div class="footer-custom__column footer-custom__column--brand">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer-custom__logo-link" style="display: inline-block; margin-bottom: 15px;">
            {{ settings.logo | image_url: width: 200 | image_tag: class: 'footer-custom__logo', loading: 'lazy', style: 'max-width: 150px; height: auto;' }}
          </a>
        {%- else -%}
          <h2 class="footer-custom__brand-name">{{ section.settings.brand_name }}</h2>
        {%- endif -%}
        <div class="footer-custom__brand-desc">{{ section.settings.brand_desc }}</div>
      </div>

      <!-- Links Column 1: Collections -->
      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Collections</h3>
        <ul class="footer-custom__linklist">
          <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
        </ul>
      </div>

      <!-- Links Column 2: Information -->
      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Information</h3>
        <ul class="footer-custom__linklist">
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
          <li><a href="/pages/about">Our Story</a></li>
        </ul>

      </div>

      <!-- Links Column 3: Follow Us -->
      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Follow Us</h3>
        <ul class="footer-custom__linklist">
          <li style="display: flex; align-items: center; gap: 8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            <a href="https://instagram.com/overlay" target="_blank">Instagram</a>
          </li>
          <li style="display: flex; align-items: center; gap: 8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            <a href="https://wa.me/yournumber" target="_blank">WhatsApp</a>
          </li>
          <li style="display: flex; align-items: center; gap: 8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
            <a href="https://tiktok.com/@overlay" target="_blank">TikTok</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="footer-custom__bottom">
    <div class="footer-custom__bottom-inner page-width-normal">
      <div class="footer-custom__copyright">
        2026 | OVERLAY DESIGNED BY <a href="https://cityreachdigital.com/" target="_blank" rel="noopener noreferrer"><span class="shimmer-text">CITYREACH DIGITAL</span></a>
      </div>
      <div class="footer-custom__bottom-right">
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "OVERLAY"
    },
    {
      "type": "richtext",
      "id": "brand_desc",
      "label": "Brand Description",
      "default": "<p>Defining the scent of architecture through avant-garde olfactory design and minimalist aesthetics.</p>"
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Column 1 Heading",
      "default": "COLLECTIONS"
    },
    {
      "type": "link_list",
      "id": "col1_menu",
      "label": "Column 1 Menu"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Column 2 Heading",
      "default": "INFORMATION"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Column 2 Menu"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "NEWSLETTER"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "OVERLAY — SENSE & ARCHITECTURE"
    }
  ]
}
{% endschema %}
