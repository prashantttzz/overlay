{%- liquid
  assign section_id = 'section-' | append: section.id
-%}

{%- style -%}
  #{{ section_id }} {
    position: relative;
    height: 400vh; /* Cinematic pacing for slower reveal */
    background-color: {{ section.settings.bg_color }};
    overflow: clip;
  }

  .engraving-reveal__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    clip-path: inset(0);
  }

  .engraving-reveal__image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: clip-path;
  }

  .engraving-reveal__image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Initial state: Centered point */
    clip-path: inset(50% 50% 50% 50% round 0px);
    will-change: clip-path, border-radius;
  }

  .engraving-reveal__image {
    width: 100%;
    height: 120%; /* Taller for upward parallax */
    top: 0;
    position: absolute;
    object-fit: cover;
    transform: scale(1.4);
    will-change: transform, top;
  }

  .engraving-reveal__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));
    z-index: 2;
    opacity: 0;
    will-change: opacity;
  }

  .engraving-reveal__content-parallax {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    max-width: 1000px;
    padding: 0 5vw;
    opacity: 1;
    will-change: transform, opacity;
  }

  .engraving-reveal__text {
    font-size: 1.15rem;
    line-height: 1.8;
    margin: 0 auto 3rem auto;
    opacity: 0;
    font-weight: 300;
    max-width: 600px;
    letter-spacing: 0.02em;
    will-change: opacity, transform;
  }

  .engraving-reveal__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #fff;
    color: #000;
    padding: 1.25rem 4rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    border: 1px solid #fff;
    opacity: 0;
    will-change: opacity, transform;
  }

  .engraving-reveal__button:hover {
    background-color: transparent;
    color: #fff;
  }

  .engraving-reveal__bg-watermark {
    font-size: clamp(2rem, 5vw, 3rem);
    font-family: var(--font-heading--family), serif;
    color: #000;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 0.9;
    white-space: nowrap;
    z-index: 5;
    pointer-events: none;
    text-align: center;
    width: 100%;
    margin-bottom: 2.5rem;
    will-change: transform, font-size, color;
  }

  @media (max-width: 768px) {
    #{{ section_id }} {
      height: 350vh;
    }
    .engraving-reveal__image-wrapper {
        clip-path: inset(30% 15% 30% 15% round 30px);
    }
    .engraving-reveal__text {
        font-size: 0.9rem;
        padding: 0 5%;
    }
    .engraving-reveal__button {
        padding: 1rem 2.5rem;
        font-size: 0.75rem;
    }
  }
{%- endstyle -%}

<section id="{{ section_id }}" class="engraving-reveal-section" data-engraving-reveal>
  <div class="engraving-reveal__sticky">

    <div class="engraving-reveal__image-container">
      <div class="engraving-reveal__image-wrapper" data-reveal-wrapper>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 2500 | image_tag: 
            class: 'engraving-reveal__image',
            loading: 'lazy',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000'
          }}
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0774/2894/9215/files/offer0bg.webp?v=1777367390" 
               class="engraving-reveal__image" 
               alt="Custom Engraving Background" 
               width="2500" height="1400" loading="lazy">
        {%- endif -%}
        <div class="engraving-reveal__overlay" data-reveal-overlay></div>
      </div>
    </div>

    <div class="engraving-reveal__content-parallax" data-reveal-content>
      <div class="engraving-reveal__bg-watermark">
        {{ section.settings.heading | default: "ETCHED IN TIME" }}
      </div>

      <div class="engraving-reveal__text" data-reveal-text>
        {{ section.settings.text | default: "Experience the ultimate luxury of customization. Every bottle tells a story, and now you can etch yours forever with our bespoke engraving service." }}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="engraving-reveal__button" data-reveal-button>
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const initEngravingReveal = () => {
      const section = document.querySelector('#{{ section_id }}');
      if (!section) return;

      const wrapper = section.querySelector('[data-reveal-wrapper]');
      const image = section.querySelector('.engraving-reveal__image');
      const content = section.querySelector('[data-reveal-content]');
      const overlay = section.querySelector('[data-reveal-overlay]');
      const watermark = section.querySelector('.engraving-reveal__bg-watermark');
      const descText = section.querySelector('[data-reveal-text]');
      const actionBtn = section.querySelector('[data-reveal-button]');

      let targetProgress = 0;
      let currentProgress = 0;
      const lerpFactor = 0.06; // Smooth inertia for cinematic feel

      const updateReveal = () => {
        const rect = section.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const sectionHeight = section.offsetHeight;
        const isMobile = window.innerWidth <= 768;
        
        const scrollOffset = -rect.top;
        const scrollRange = sectionHeight - windowHeight;
        
        targetProgress = Math.max(0, Math.min(1, scrollOffset / scrollRange));
        currentProgress += (targetProgress - currentProgress) * lerpFactor;

        // 1. Expansion Phase (First 40%)
        const expansionEnd = 0.45;
        const linExp = Math.min(1, currentProgress / expansionEnd);
        const expProg = 1 - Math.pow(1 - linExp, 3); // Smooth ease out
        
        const initialH = 50, initialV = 50, initialR = isMobile ? 30 : 60;
        const finalInsetH = initialH * (1 - expProg);
        const finalInsetV = initialV * (1 - expProg);
        const finalRadius = initialR * (1 - expProg);

        if (wrapper) {
          wrapper.style.clipPath = `inset(${finalInsetV}% ${finalInsetH}% ${finalInsetV}% ${finalInsetH}% round ${finalRadius}px)`;
        }
        
        if (image) {
          const zoom = 1.4 - (expProg * 0.4);
          image.style.transform = `scale(${zoom})`;
          // Subtle upward parallax
          const imageY = currentProgress * -10;
          image.style.top = `${imageY}%`;
        }

        // 2. Watermark Centered Animation
        if (watermark) {
          const colorVal = Math.floor(255 * expProg);
          watermark.style.color = `rgb(${colorVal}, ${colorVal}, ${colorVal})`;
          
          const baseSize = isMobile ? 5 : 2.5;
          const finalSize = isMobile ? 8 : 6;
          const currentSize = baseSize + (expProg * (finalSize - baseSize));
          watermark.style.fontSize = `${currentSize}vw`;

          // Center-point alignment: Start slightly right, end slightly left of perfect center
          const shiftStart = 1.5;
          const shiftEnd = -1.5;
          const currentShift = isMobile ? 0 : (shiftStart + (expProg * (shiftEnd - shiftStart)));
          watermark.style.transform = `translateX(${currentShift}vw)`;
        }

        // 3. Narrative Reveal
        if (expProg > 0.8) {
          const contentProg = Math.max(0, (expProg - 0.8) * 5);
          if (overlay) overlay.style.opacity = Math.min(0.6, contentProg);
          
          const subAlpha = Math.max(0, (expProg - 0.9) * 10);
          if (descText) {
            descText.style.opacity = subAlpha;
            descText.style.transform = `translateY(${(1 - subAlpha) * 20}px)`;
          }
          if (actionBtn) {
            actionBtn.style.opacity = subAlpha;
            actionBtn.style.transform = `translateY(${(1 - subAlpha) * 30}px)`;
          }
        } else {
          if (overlay) overlay.style.opacity = 0;
          if (descText) descText.style.opacity = 0;
          if (actionBtn) actionBtn.style.opacity = 0;
        }

        requestAnimationFrame(updateReveal);
      };

      requestAnimationFrame(updateReveal);
    };

    initEngravingReveal();
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', initEngravingReveal);
    }
  })();
</script>

{% schema %}
{
  "name": "Custom Engraving Reveal",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Watermark)",
      "default": "ETCHED IN TIME"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Experience the ultimate luxury of customization. Every bottle tells a story, and now you can etch yours forever with our bespoke engraving service."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Personalize Yours"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom Engraving Reveal"
    }
  ]
}
{% endschema %}
