{%- style -%}
  #scent-layering-{{ section.id }} {
    position: relative;
    background-color: #fff; /* Initial White */
    color: #000;
    overflow: clip;
    transition: background-color 0.8s cubic-bezier(0.4, 0, 0.2, 1), color 0.8s ease;
  }

  #scent-layering-{{ section.id }}.is-dark {
    background-color: #000;
    color: #fff;
  }

  .sl-monolith__scroll-container {
    height: 800vh; /* Extended scroll for cinematic pacing */
    position: relative;
  }

  .sl-monolith__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Centered Text Overlay */
  .sl-monolith__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 20;
    pointer-events: none;
  }

  /* Drifting Background Notes */
  .sl-monolith__notes-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .sl-monolith__note {
    position: absolute;
    font-size: 10px;
    letter-spacing: 0.8em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.15); /* Increased visibility */
    white-space: nowrap;
    will-change: transform;
  }

  /* Large Background Quote */
  .sl-monolith__slogan {
    position: absolute;
    top: 50%;
    left: 10vw;
    transform: translateY(-50%);
    font-family: var(--font-heading--family), serif;
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 0.85;
    font-weight: 800;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.08); /* Increased visibility */
    width: 600px;
    z-index: 0;
    pointer-events: none;
  }

  /* Background Watermark */
  .sl-monolith__watermark {
    position: absolute;
    top: 50%;
    left: 3vw;
    transform: translateY(-50%);
    font-family: var(--font-heading--family), serif;
    font-size: clamp(8rem, 15vw, 12rem);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2); /* Increased visibility */
    pointer-events: none;
    z-index: 1;
    white-space: nowrap;
    writing-mode: vertical-lr;
    transform: translateY(-50%) rotate(180deg);
  }

  /* Progress Line */
  .sl-monolith__progress-track {
    position: absolute;
    top: 50%;
    left: 4vw;
    transform: translateY(-50%);
    height: 300px;
    width: 1px;
    background: rgba(255, 255, 255, 0.1);
    z-index: 15;
  }

  .sl-monolith__progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: #fff;
    transition: height 0.3s ease;
  }

  .sl-monolith__feature {
    position: absolute;
    text-align: left;
    left: 10vw;
    width: min(450px, 80vw);
    opacity: 0;
    z-index: 10;
    will-change: transform, opacity, filter;
    pointer-events: none;
  }

  .sl-monolith__feature.is-active {
    pointer-events: auto;
  }

  .sl-monolith__label {
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
    display: block;
  }

  .sl-monolith__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    line-height: 1.1;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.05em;
  }

  .sl-monolith__text {
    font-size: clamp(0.9rem, 1.1vw, 1.05rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    max-width: 400px;
    margin: 1.5rem 0 0;
    text-wrap: balance;
  }

  /* 3D Bottle Visual */
  .sl-monolith__visual {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40vw;
    height: 65vh;
    transform: translate3d(-50%, -50%, 0);
    z-index: 10;
    pointer-events: none;
    will-change: transform, left, opacity;
  }

  #sl-monolith-viewer-{{ section.id }} {
    width: 100%;
    height: 100%;
    --poster-color: transparent;
    outline: none;
  }

  /* Callout Labels */
  .sl-monolith__callouts {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    will-change: opacity;
  }

  .sl-monolith__callout {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    will-change: transform, opacity, filter;
  }

  /* Entrance directions - deeper offset for "coming from side" */
  .callout--top, .callout--bottom { transform: translateX(40px); }
  .callout--mid { transform: translateX(-40px); }

  .sl-monolith__callout-line {
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    width: 0;
    will-change: width;
  }

  .sl-monolith__callout-text {
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    white-space: nowrap;
    font-weight: 600;
    background: rgba(0,0,0,0.2);
    padding: 2px 4px;
    border-radius: 2px;
    will-change: transform, opacity;
  }

  /* Specific Label Positions */
  .callout--top { top: 15%; right: 15%; flex-direction: row; }
  .callout--mid { top: 50%; left: 5%; flex-direction: row-reverse; }
  .callout--bottom { bottom: 20%; right: 10%; flex-direction: row; }

  @media (max-width: 768px) {
    .sl-monolith__callouts { display: none; }
    
    .sl-monolith__title {
      font-size: clamp(1.5rem, 7vw, 2.2rem);
      text-align: center;
      letter-spacing: 0.02em;
    }

    .sl-monolith__visual {
      width: 65vw;
      height: 35vh;
      top: 38% !important; /* Shifted lower to be closer to text */
    }

    .sl-monolith__feature {
      left: 50% !important;
      width: 88vw;
      bottom: 18%; /* Shifted higher to close the gap */
      top: auto !important;
      text-align: center;
      padding: 1.25rem 1.5rem;
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transform: translate3d(-50%, 20px, 0);
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .sl-monolith__text {
      font-size: 0.8rem;
      text-align: center;
      margin: 0.8rem auto 0;
      max-width: 100%;
      opacity: 0.7;
    }

    .sl-monolith__label {
      text-align: center;
      margin-bottom: 0.35rem;
      font-size: 8px;
      letter-spacing: 0.3em;
    }

    .sl-monolith__slogan {
      font-size: 2.5rem;
      width: 90vw;
      left: 5vw;
      opacity: 0.03 !important;
    }

    .sl-monolith__watermark {
      display: none; 
    }

    .sl-monolith__progress-track {
      left: auto;
      right: 5vw;
      height: 150px;
      top: 32%;
    }
  }
{%- endstyle -%}

