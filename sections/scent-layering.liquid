<script>
  (function() {
    const section = document.querySelector('#scent-layering-{{ section.id }}');
    if (!section) return;

    const scrollContainer = section.querySelector('.sl-monolith__scroll-container');
    const visual = section.querySelector('.sl-monolith__visual');
    const features = section.querySelectorAll('.sl-monolith__feature');
    const progressBar = section.querySelector('.sl-monolith__progress-bar');
    const notes = section.querySelectorAll('.sl-monolith__note');
    const calloutContainer = section.querySelector('.sl-monolith__callouts');
    const callouts = section.querySelectorAll('.sl-monolith__callout');
    const model = section.querySelector('#sl-monolith-viewer-{{ section.id }}');

    let targetProgress = 0;
    let currentProgress = 0;
    let lastProgress = 0; 
    let currentActiveIndex = -1;
    let isUserInteracting = false;
    const lerpFactor = 0.3; // Responsive but controlled

    const labelSets = [
      ["MAGNETIC CLOSURE", "ARTISAN GLASS", "WEIGHTED FOUNDATION"],
      ["MOLECULAR BONDING", "LAYERED HARMONY", "SEAMLESS BLEND"],
      ["DYNAMIC REACTION", "LIQUID TOUCH", "INSTANT ABSORPTION"],
      ["ENDURING SILLAGE", "SCENT EVOLUTION", "LASTING PRESENCE"]
    ];

    // Detect user interaction with 3D model
    model?.addEventListener('pointerdown', () => isUserInteracting = true);
    window.addEventListener('pointerup', () => isUserInteracting = false);

    // Narrative Snapping: Aggressive state completion
    let snapTimer;
    window.addEventListener('scroll', () => {
      clearTimeout(snapTimer);
      snapTimer = setTimeout(() => {
        const isSettled = targetProgress > 0.38 && targetProgress < 0.82;
        if (isSettled) {
          const fRange = 0.8 - 0.4;
          const fProgress = (targetProgress - 0.4) / fRange;
          
          const numFeatures = features.length;
          // Forced rounding to nearest state center
          const nearestIdx = Math.round(fProgress * numFeatures - 0.5);
          const snapIdx = Math.max(0, Math.min(numFeatures - 1, nearestIdx));
          const snapF = (snapIdx + 0.5) / numFeatures;
          
          targetProgress = 0.4 + (snapF * fRange);
        }
      }, 50); // High-frequency snap
    }, { passive: true });

    function updateMonolith() {
      const rect = scrollContainer.getBoundingClientRect();
      const scrollRange = rect.height - window.innerHeight;
      if (scrollRange <= 0) return;

      const newTarget = Math.max(0, Math.min(1, -rect.top / scrollRange));
      
      // If actively scrolling, follow perfectly. If stopped, snapTimer takes over.
      if (Math.abs(newTarget - targetProgress) > 0.005) {
        targetProgress = newTarget;
      }

      currentProgress += (targetProgress - currentProgress) * lerpFactor;

      const delta = currentProgress - lastProgress;
      lastProgress = currentProgress;

      const isMobile = window.innerWidth <= 768;

      if (currentProgress > 0.02) section.classList.add('is-dark');
      else section.classList.remove('is-dark');

      let leftPos = 50;
      let opacity = 1;
      let scale = 1;
      let exposure = 1;
      let orbitX = 0;
      let pitch = 90; 
      
      if (currentProgress < 0.15) {
        leftPos = 50;
        scale = 1.4 + (currentProgress * 0.5); 
        exposure = 0.6 + (currentProgress * 2);
        orbitX = 0;
      } else if (currentProgress < 0.4) {
        const sweepProgress = (currentProgress - 0.15) / 0.25;
        leftPos = 50 + (sweepProgress * (isMobile ? 0 : 25));
        scale = 1.9 - (sweepProgress * 0.9);
        orbitX = sweepProgress * 360; 
        exposure = 0.9 + (sweepProgress * 0.3);
      } else if (currentProgress < 0.8) {
        leftPos = isMobile ? 50 : 75;
        scale = 1;
        exposure = 1.2;
        
        const fRange = 0.8 - 0.4;
        const fProgress = (currentProgress - 0.4) / fRange;
        
        orbitX = 360 + (fProgress * 720); 
        pitch = 90 + Math.sin(fProgress * Math.PI * 2) * 10;
      } else {
        const returnProgress = (currentProgress - 0.8) / 0.2;
        leftPos = (isMobile ? 50 : 75) - (returnProgress * (isMobile ? 0 : 25));
        scale = 1 + (returnProgress * 0.4);
        orbitX = 1080 - (returnProgress * 360); 
        exposure = 1.2 - (returnProgress * 0.2);
      }

      if (currentProgress < 0.05) opacity = opacity;

      visual.style.left = `${leftPos}%`;
      visual.style.opacity = opacity.toFixed(3);
      visual.style.transform = `translate3d(-50%, -50%, 0) scale(${scale.toFixed(3)})`;
      
      const isSettled = currentProgress >= 0.4 && currentProgress <= 0.8;

      if (isSettled) {
        const fRange = 0.8 - 0.4;
        const fProgress = (currentProgress - 0.4) / fRange;
        
        if (progressBar) progressBar.style.height = `${fProgress * 100}%`;

        // 1. Feature Text Sliding
        features.forEach((f, i) => {
          const featureTarget = (i + 0.5) / features.length;
          const dist = fProgress - featureTarget;
          const absDist = Math.abs(dist);
          // Aggressive curve for "binary" visibility (no in-between)
          const threshold = 1.0 / features.length; 
          let fOpacity = 0;
          let translateY = 0;
          let blur = 0;

          if (absDist < threshold) {
            // Power of 4 creates a very steep transition that snaps to 100% focus
            fOpacity = Math.max(0, 1 - Math.pow(absDist / (threshold * 0.5), 4));
            translateY = dist * 100; 
            blur = 0;
          }

          const baseTranslateX = isMobile ? '-50%' : '0';
          f.style.opacity = fOpacity.toFixed(3);
          f.style.transform = `translate3d(${baseTranslateX}, ${translateY.toFixed(2)}px, 0)`;
          f.style.filter = `none`;
          f.style.color = '#ffffff';
          f.style.zIndex = "40"; 
          
          if (fOpacity > 0.1) {
            f.classList.add('is-active');
            f.style.pointerEvents = 'auto';
          } else {
            f.classList.remove('is-active');
            f.style.pointerEvents = 'none';
          }
        });

        // 2. Technical Callouts Sliding & Line Expansion
        if (calloutContainer) {
          const activeIndex = Math.floor(fProgress * features.length);
          const chapterProgress = (fProgress * features.length) % 1;
          const chapterDist = Math.abs(chapterProgress - 0.5);
          
          const slideThreshold = 0.45; 
          let labelOpacity = 1;
          let labelSlide = 0;

          if (chapterDist > slideThreshold) {
            labelOpacity = Math.max(0, 1 - ((chapterDist - slideThreshold) / (0.5 - slideThreshold)));
            labelSlide = (chapterDist - slideThreshold) * 30; 
          }

          // Swap text when faded or at index change
          if (activeIndex !== currentActiveIndex && labelOpacity < 0.5) {
            currentActiveIndex = activeIndex;
            const set = labelSets[activeIndex];
            callouts.forEach((c, i) => {
              const textSpan = c.querySelector('.sl-monolith__callout-text');
              if (textSpan && set[i]) textSpan.textContent = set[i];
            });
          }

          const enterStart = 0.35;
          const enterEnd = 0.45;
          const enterProgress = Math.max(0, Math.min(1, (currentProgress - enterStart) / (enterEnd - enterStart)));
          
          calloutContainer.style.opacity = enterProgress.toFixed(3);
          calloutContainer.style.zIndex = "50"; 
          
          callouts.forEach((c, i) => {
            const sideFactor = c.classList.contains('callout--mid') ? -1 : 1;
            const slide = (labelSlide * sideFactor);
            
            c.style.opacity = labelOpacity.toFixed(3);
            c.style.transform = `translateX(${slide.toFixed(2)}px)`;
            c.style.filter = `none`; 

            const line = c.querySelector('.sl-monolith__callout-line');
            const text = c.querySelector('.sl-monolith__callout-text');
            if (line) line.style.width = `${(labelOpacity * 40).toFixed(0)}px`;
            if (text) {
              const textInnerSlide = (1 - labelOpacity) * 10 * sideFactor;
              text.style.transform = `translateX(${textInnerSlide.toFixed(2)}px)`;
            }
          });
        }

        notes.forEach((note, i) => {
          const speed = (i + 1) * 30;
          note.style.transform = `translate3d(${fProgress * speed}px, ${Math.sin(fProgress * 10 + i) * 20}px, 0)`;
        });
      } else {
        currentActiveIndex = -1;
        features.forEach(f => {
            f.style.opacity = 0;
            f.classList.remove('is-active');
        });
        if (progressBar) progressBar.style.height = currentProgress > 0.8 ? '100%' : '0%';
        if (calloutContainer) calloutContainer.style.opacity = 0;
      }

      if (model && !isUserInteracting) {
        const leanLimit = 10;
        const lean = Math.max(-leanLimit, Math.min(leanLimit, delta * 1500));
        model.cameraOrbit = `${orbitX + lean}deg ${pitch}deg 105%`;
        model.exposure = exposure;
        model.shadowIntensity = 1.5 - (exposure * 0.5);
      }

      requestAnimationFrame(updateMonolith);
    }

    window.addEventListener('resize', () => {
      // Logic inside updateMonolith handles resizing via rect checks
    });
    
    // Start the smooth animation loop
    requestAnimationFrame(updateMonolith);
    
    model?.addEventListener('load', () => {
      // Model loaded, loop will pick it up
    });
  })();
</script>

