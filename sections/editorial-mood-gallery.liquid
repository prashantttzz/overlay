{%- style -%}
  #editorial-mood-{{ section.id }} {
    background-color: #fff;
    color: #000;
    padding: 140px 0;
    overflow: hidden;
    position: relative;
  }

  .mood-gallery__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5vw;
  }

  .mood-gallery__header {
    margin-bottom: 100px;
    text-align: center;
  }

  .mood-gallery__eyebrow {
    font-size: 11px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.4);
    display: block;
    margin-bottom: 1.5rem;
  }

  .mood-gallery__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-transform: uppercase;
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: #000;
  }

  .mood-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px;
    align-items: flex-start;
  }

  .mood-gallery__item {
    position: relative;
    will-change: transform;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* Staggered Offsets */
  .item--0 { transform: translateY(0); }
  .item--1 { transform: translateY(120px); }
  .item--2 { transform: translateY(-40px); }

  .mood-gallery__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: #f7f7f7;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  .mood-gallery__image {
    width: 100%;
    height: 120%;
    object-fit: cover;
    position: absolute;
    top: -10%;
    left: 0;
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .mood-gallery__item:hover .mood-gallery__image {
    scale: 1.05;
  }

  .mood-gallery__caption {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.5);
    margin-bottom: 0.5rem;
    display: block;
  }

  .mood-gallery__item-title {
    font-family: var(--font-heading--family), serif;
    font-size: 1.25rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #000;
    line-height: 1.2;
  }



  @media (max-width: 768px) {
    #editorial-mood-{{ section.id }} {
      padding: 100px 0;
    }
    .mood-gallery__grid {
      grid-template-columns: 1fr;
      gap: 80px;
    }
    .mood-gallery__item {
      transform: none !important;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .mood-gallery__image-wrap {
      width: 100%;
      max-width: 400px;
    }

  }
{%- endstyle -%}

<section id="editorial-mood-{{ section.id }}" data-mood-gallery>
  <div class="mood-gallery__container">
    
    <div class="mood-gallery__header">
      <span class="mood-gallery__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="mood-gallery__title">{{ section.settings.heading }}</h2>
    </div>

    <div class="mood-gallery__grid">
      {%- liquid
        assign products = section.settings.collection.products
        assign parallax_factors = "0.04,0.08,0.06" | split: ","
      -%}

      {%- if products.size > 0 -%}
        {%- for product in products limit: 3 -%}
          <a href="{{ product.url }}" class="mood-gallery__item item--{{ forloop.index0 }}" data-parallax-factor="{{ parallax_factors[forloop.index0] }}">
            <div class="mood-gallery__image-wrap">
              <img src="{{ product.featured_image | img_url: '1000x' }}" 
                   alt="{{ product.title }}" 
                   height=""
                   width=""
                   class="mood-gallery__image" 
                   loading="lazy">
            </div>
            <span class="mood-gallery__caption">ARCHIVE / {{ product.type | upcase | default: "PRODUCT" }}</span>
            <h3 class="mood-gallery__item-title">{{ product.title | upcase }}</h3>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="mood-gallery__item item--{{ forloop.index0 }}" data-parallax-factor="0.05">
            <div class="mood-gallery__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'mood-gallery__image' }}
            </div>
            <span class="mood-gallery__caption">ARCHIVE / 00{{ i }}</span>
            <h3 class="mood-gallery__item-title">ARCHIVAL PIECE {{ i }}</h3>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>



  </div>
</section>

<script>
  (function() {
    const initMoodGallery = () => {
      const section = document.querySelector('#editorial-mood-{{ section.id }}');
      if (!section) return;

      const items = section.querySelectorAll('.mood-gallery__item');
      const images = section.querySelectorAll('.mood-gallery__image');

      const handleScroll = () => {
        const rect = section.getBoundingClientRect();
        const winH = window.innerHeight;
        
        if (rect.top > winH || rect.bottom < 0) return;

        const scrollDist = winH - rect.top;
        
        items.forEach((item, index) => {
          const factor = parseFloat(item.dataset.parallaxFactor) || 0.05;
          const y = scrollDist * factor;
          
          if (window.innerWidth > 768) {
             const baseOffsets = [0, 120, -40];
             const baseOffset = baseOffsets[index] || 0;
             item.style.transform = `translateY(${baseOffset + y}px)`;
          }

          const imgFactor = (index + 1) * 0.02;
          const imgY = scrollDist * imgFactor * -1;
          if (images[index]) {
            images[index].style.transform = `translateY(${imgY}px) scale(1.15)`;
          }
        });
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();
    };

    document.addEventListener('DOMContentLoaded', initMoodGallery);
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', initMoodGallery);
    }
  })();
</script>

{% schema %}
{
  "name": "Editorial Mood Gallery",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE ARCHIVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "REFRACTED VISIONS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },

  ],
  "presets": [
    {
      "name": "Editorial Mood Gallery"
    }
  ]
}
{% endschema %}
